<mxfile host="app.diagrams.net">
  <diagram name="Provider Classification Logic" id="provider_logic">
    <mxGraphModel dx="1200" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Start -->
        <mxCell id="start" value="Start" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="40" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- Check INN Ruleset -->
        <mxCell id="checkINN" value="Does provider obey INN ruleset?" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="40" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- PAR INN PROVIDER -->
        <mxCell id="parINN" value="PAR INN PROVIDER" style="rounded=1;fillColor=#d5e8d4;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="20" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- Check NON PAR conditions -->
        <mxCell id="checkNonPar" value="Is ProviderFlag = N OR NetworkID is NULL OR Steerage = 5?" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="140" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- NON PAR PROVIDER -->
        <mxCell id="nonPar" value="NON PAR PROVIDER" style="rounded=1;fillColor=#f8cecc;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="130" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- PAR OON PROVIDER -->
        <mxCell id="parOON" value="PAR OON PROVIDER" style="rounded=1;fillColor=#dae8fc;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="230" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Connectors -->
        <mxCell id="edge1" style="endArrow=block" edge="1" source="start" target="checkINN" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge2" value="Yes" style="endArrow=block" edge="1" source="checkINN" target="parINN" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge3" value="No" style="endArrow=block" edge="1" source="checkINN" target="checkNonPar" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge4" value="Yes" style="endArrow=block" edge="1" source="checkNonPar" target="nonPar" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge5" value="No" style="endArrow=block" edge="1" source="checkNonPar" target="parOON" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
